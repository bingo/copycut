# 复制为 .env.local 并填入各 OAuth 应用的凭据。
# 回调地址(Redirect URI)统一填:{站点地址}/api/auth/{provider}/callback
# 本地开发即:
#   http://localhost:3000/api/auth/google/callback
#   http://localhost:3000/api/auth/github/callback
#   http://localhost:3000/api/auth/facebook/callback

# 会话 cookie 的 HMAC 签名密钥,生产环境必填(openssl rand -hex 32)
AUTH_SECRET=

# 生产站点地址,用于生成邮件里的激活链接。
# Vercel 生产环境建议填自有域名,如 https://copycut.example.com;
# 若暂未绑定域名,可填 https://your-project.vercel.app。
APP_URL=

# 注册激活邮件通过 Resend 发送(https://resend.com/api-keys)。
# 不配置时不发真实邮件:激活链接打印到服务端 console,
# 并在注册接口响应的 devActivationUrl 字段返回(仅限本地开发调试)。
RESEND_API_KEY=
# 发件人,需为 Resend 已验证域名下的地址,如 "CopyCut <noreply@yourdomain.com>";
# 不填则用 Resend 测试地址 onboarding@resend.dev(只能发给自己的账号邮箱)
MAIL_FROM=

# 临时小流量发信通道:Gmail API fallback。
# 未配置 RESEND_API_KEY 且配置了以下变量时,注册激活邮件会从你的 Gmail 发出。
# Google OAuth Client 需允许 Gmail API scope:
#   https://www.googleapis.com/auth/gmail.send
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# 真实发件邮箱,必须是授权 Gmail 账号或其已配置的 Send mail as 别名。
GMAIL_FROM=
# 可选发件展示名,不填则使用 CopyCut。
GMAIL_FROM_NAME=

# 用户数据持久化:Vercel Marketplace 安装 Neon Postgres 后会注入 DATABASE_URL。
# 本地执行迁移前可用 `vercel env pull .env.local` 拉取,或手动 export。
DATABASE_URL=

# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth App:
#   https://github.com/settings/developers (OAuth Apps)
# Authorization callback URL:
#   本地: http://localhost:3000/api/auth/github/callback
#   生产: https://your-domain.example.com/api/auth/github/callback
# 生产环境还需将 APP_URL 设置为同一个站点 origin,确保 redirect_uri 与 GitHub 配置一致。
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# https://developers.facebook.com/apps (Facebook Login)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
